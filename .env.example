# ── Required ────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Recommended providers: Neon, Supabase, Railway.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Random secret string used for session signing (generate with: openssl rand -hex 32)
SESSION_SECRET=replace-with-a-long-random-string

# ── Development only (not needed for Vercel) ─────────────────────────────────
PORT=3000
BASE_PATH=/
